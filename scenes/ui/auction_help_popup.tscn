[gd_scene format=3 uid="uid://auction_help_1"]

[ext_resource type="Script" uid="uid://qvxodww0rk3w" path="res://src/ui/AuctionHelpPopup.gd" id="1_help"]

[node name="AuctionHelpPopup" type="Control"]
script = ExtResource("1_help")
visible = false
custom_minimum_size = Vector2(520, 480)
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -260.0
offset_top = -240.0
offset_right = 260.0
offset_bottom = 240.0

[node name="Panel" type="PanelContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2

[node name="TitleBar" type="HBoxContainer" parent="Panel/VBox"]
layout_mode = 2

[node name="Title" type="Label" parent="Panel/VBox/TitleBar"]
layout_mode = 2
size_flags_horizontal = 3
text = "梦境残市 - 新手引导"
theme_override_font_sizes/font_size = 14

[node name="CloseBtn" type="Button" parent="Panel/VBox/TitleBar"]
layout_mode = 2
text = "X"

[node name="Scroll" type="ScrollContainer" parent="Panel/VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="Content" type="VBoxContainer" parent="Panel/VBox/Scroll"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Step1" type="PanelContainer" parent="Panel/VBox/Scroll/Content"]
layout_mode = 2

[node name="Label" type="Label" parent="Panel/VBox/Scroll/Content/Step1"]
layout_mode = 2
text = "1.  拍品从哪来？
每圈走完，你杀掉的敌人各贡献一件服务进入拍场。
最多同时出现 3 件，没人要的下圈继续挂。"
autowrap_mode = 3

[node name="Arrow1" type="Label" parent="Panel/VBox/Scroll/Content"]
layout_mode = 2
text = "          |"
horizontal_alignment = 1

[node name="Step2" type="PanelContainer" parent="Panel/VBox/Scroll/Content"]
layout_mode = 2

[node name="Label" type="Label" parent="Panel/VBox/Scroll/Content/Step2"]
layout_mode = 2
text = "2.  怎么出价？
走路时随时打开残市面板。
每件服务有独立「出价」按钮，点击立即扣钱锁定。
同一圈可以同时对多件服务出价。"
autowrap_mode = 3

[node name="Arrow2" type="Label" parent="Panel/VBox/Scroll/Content"]
layout_mode = 2
text = "          |"
horizontal_alignment = 1

[node name="Step3" type="PanelContainer" parent="Panel/VBox/Scroll/Content"]
layout_mode = 2

[node name="Label" type="Label" parent="Panel/VBox/Scroll/Content/Step3"]
layout_mode = 2
text = "3.  圈末结算
影子甲（激进）、影子乙（蓄势）同时出价。
出价最高者赢得服务，其余全额退款。
上圈结果在面板顶部，按金额排序显示。"
autowrap_mode = 3

[node name="Arrow3" type="Label" parent="Panel/VBox/Scroll/Content"]
layout_mode = 2
text = "          |"
horizontal_alignment = 1

[node name="Step4" type="PanelContainer" parent="Panel/VBox/Scroll/Content"]
layout_mode = 2

[node name="Label" type="Label" parent="Panel/VBox/Scroll/Content/Step4"]
layout_mode = 2
text = "4.  服务栏（最多 5 格）
赢得的服务进入底部服务栏。
点击图标弹出操作界面，手动激活。
栏满时需先丢弃一个才能接收新的。"
autowrap_mode = 3

[node name="Arrow4" type="Label" parent="Panel/VBox/Scroll/Content"]
layout_mode = 2
text = "          |"
horizontal_alignment = 1

[node name="Step5" type="PanelContainer" parent="Panel/VBox/Scroll/Content"]
layout_mode = 2

[node name="Label" type="Label" parent="Panel/VBox/Scroll/Content/Step5"]
layout_mode = 2
text = "5.  六种服务
  规则复制   把地块规则复制到另一格
  词条改写   改触发N值或数值（最多+50%）
  词条融合   两个同类词条合并（总和x0.8）
  敌人赦免   下3只指定敌人自动掉落组件
  删除特赦   下次删除免费且不计全局次数
  压力延缓   世界压力 -1 圈"
autowrap_mode = 3

[node name="Tip" type="Label" parent="Panel/VBox/Scroll/Content"]
layout_mode = 2
theme_override_colors/font_color = Color(0.5, 0.5, 0.7, 1)
theme_override_font_sizes/font_size = 10
text = "提示：影子甲总是激进出价，影子乙会蓄势等到存够钱再全押。\n观察他们的金额和兴趣条，可以找到低价捡漏的机会。"
autowrap_mode = 3
